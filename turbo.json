{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": [
    ".editorconfig",
    ".prettierignore",
    ".prettierrc.json",
    "eslint.config.mjs"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "e2e": {
      "cache": false
    },
    "e2e:install": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "format:check": {
      "dependsOn": ["^format:check"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}
