{
  "projects": [
    {
      "id": "demo",
      "adapter": "stencil",
      "adapterPackage": "@qwik-custom-elements/adapter-stencil",
      "source": {
        "type": "CEM",
        "path": "./packages/test-stencil-lib/custom-elements.json"
      },
      "adapterOptions": {
        "runtime": {
          "loaderImport": "@qwik-custom-elements/test-stencil-lib/loader",
          "hydrateImport": "@qwik-custom-elements/test-stencil-lib/hydrate"
        }
      },
      "outDir": "./apps/qwik-demo/src/generated",
      "cleanOutput": true
    },
    {
      "id": "demo-csr",
      "adapter": "stencil",
      "adapterPackage": "@qwik-custom-elements/adapter-stencil",
      "source": {
        "type": "CEM",
        "path": "./packages/test-stencil-lib/custom-elements.json"
      },
      "adapterOptions": {
        "runtime": {
          "loaderImport": "@qwik-custom-elements/test-stencil-lib/loader"
        }
      },
      "outDir": "./apps/qwik-demo/src/generated-csr",
      "cleanOutput": true
    }
  ]
}
