{
  "name": "@qwik-custom-elements/test-stencil-lib",
  "version": "0.0.0",
  "private": true,
  "description": "Stencil Component Starter",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/stencil-js-lib/stencil-js-lib.esm.js",
  "exports": {
    ".": {
      "import": "./dist/stencil-js-lib/stencil-js-lib.esm.js",
      "require": "./dist/stencil-js-lib/stencil-js-lib.cjs.js"
    },
    "./my-component": {
      "import": "./dist/components/my-component.js",
      "types": "./dist/components/my-component.d.ts"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs",
      "types": "./loader/index.d.ts"
    },
    "./hydrate": {
      "import": "./hydrate/index.mjs",
      "require": "./hydrate/index.js",
      "types": "./hydrate/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stenciljs/component-starter.git"
  },
  "files": [
    "dist/",
    "loader/",
    "hydrate/"
  ],
  "scripts": {
    "build": "stencil build",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "dev": "stencil build --dev --watch",
    "format": "node -e \"console.log('test-stencil-lib format noop')\"",
    "start": "stencil build --dev --watch --serve",
    "lint": "node -e \"console.log('test-stencil-lib lint noop')\"",
    "test": "stencil-test",
    "test:watch": "stencil-test --watch",
    "generate": "stencil generate"
  },
  "devDependencies": {
    "@stencil/core": "^4.27.1",
    "@stencil/sass": "^3.2.3",
    "@stencil/vitest": "^1.8.3",
    "@types/node": "^22.13.5",
    "@vitest/browser-playwright": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "license": "MIT"
}
