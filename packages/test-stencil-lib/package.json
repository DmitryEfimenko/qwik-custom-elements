{
  "name": "@qwik-custom-elements/test-stencil-lib",
  "version": "0.0.0",
  "private": true,
  "description": "Stencil Component Starter",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/stencil-js-lib/stencil-js-lib.esm.js",
  "exports": {
    ".": {
      "import": "./dist/stencil-js-lib/stencil-js-lib.esm.js",
      "require": "./dist/stencil-js-lib/stencil-js-lib.cjs.js"
    },
    "./my-component": {
      "types": "./dist/components/my-component.d.ts",
      "import": "./dist/components/my-component.js"
    },
    "./loader": {
      "types": "./loader-bundler/index.d.ts",
      "import": "./loader-bundler/index.js"
    },
    "./hydrate": {
      "types": "./hydrate/index.d.ts",
      "import": "./hydrate/index.mjs",
      "require": "./hydrate/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stenciljs/component-starter.git"
  },
  "files": [
    "dist/",
    "loader-bundler/",
    "hydrate/"
  ],
  "scripts": {
    "build": "stencil build",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "dev": "stencil build --dev --watch",
    "format": "prettier --write . --config ../../.prettierrc.json --ignore-path ../../.prettierignore",
    "format:check": "prettier --check . --config ../../.prettierrc.json --ignore-path ../../.prettierignore",
    "start": "stencil build --dev --watch --serve",
    "lint": "eslint \"src/**/*.{ts,tsx}\" stencil.config.ts vitest.config.ts vitest-setup.ts --ignore-pattern \"**/*.d.ts\" --no-error-on-unmatched-pattern",
    "test": "stencil-test",
    "test:watch": "stencil-test --watch",
    "generate": "stencil generate"
  },
  "devDependencies": {
    "@stencil/core": "^4.27.1",
    "@stencil/sass": "^3.2.3",
    "@stencil/vitest": "^1.8.3",
    "@types/node": "^22.13.5",
    "@vitest/browser-playwright": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "license": "MIT"
}
