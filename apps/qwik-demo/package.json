{
  "name": "qwik-demo",
  "description": "Blank project with routing included",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "check-types": "tsc --incremental --noEmit",
    "deploy": "echo 'Run \"pnpm run qwik add\" to install a server adapter'",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "format": "prettier --write . --config ../../.prettierrc.json --ignore-path ../../.prettierignore",
    "format:check": "prettier --check . --config ../../.prettierrc.json --ignore-path ../../.prettierignore",
    "lint": "eslint \"src/**/*.ts*\"",
    "dev:e2e": "pnpm --filter @qwik-custom-elements/test-stencil-lib run build && vite --host 127.0.0.1 --port 4173 --strictPort --mode ssr",
    "preview": "qwik build preview && vite preview --open --port 4173 --strictPort",
    "preview:e2e": "pnpm --filter @qwik-custom-elements/test-stencil-lib run build && qwik build preview && vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "start": "vite --open --mode ssr",
    "e2e:install": "playwright install chromium",
    "e2e": "playwright test",
    "e2e:dev": "node -e \"const cp=require('node:child_process');const result=cp.spawnSync('playwright',['test'],{stdio:'inherit',shell:true,env:{...process.env,PLAYWRIGHT_RUNTIME:'dev'}});process.exit(result.status??1);\"",
    "e2e:preview": "node -e \"const cp=require('node:child_process');const result=cp.spawnSync('playwright',['test'],{stdio:'inherit',shell:true,env:{...process.env,PLAYWRIGHT_RUNTIME:'preview'}});process.exit(result.status??1);\"",
    "test": "node -e \"console.log('qwik-demo test noop')\"",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2",
    "@qwik-custom-elements/adapter-stencil": "workspace:*",
    "@qwik-custom-elements/test-stencil-lib": "workspace:*",
    "@eslint/js": "^9",
    "@types/node": "20.19.0",
    "eslint": "9.32.0",
    "eslint-plugin-qwik": "^1.19.2",
    "globals": "16.4.0",
    "prettier": "3.6.2",
    "typescript": "5.4.5",
    "typescript-eslint": "8.38.0",
    "typescript-plugin-css-modules": "latest",
    "tsx": "^4.20.6",
    "undici": "*",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "^4.2.1"
  }
}
